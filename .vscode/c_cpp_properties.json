{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "/usr/include",
                "/usr/include/wlroots-0.18",
                "/usr/include/wayland",
                "/usr/include/libinput",
                "/usr/include/pixman-1",
                "${workspaceFolder}/build"
            ],
            "defines": [
                "WLR_USE_UNSTABLE",
                "_GNU_SOURCE"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "intelliSenseMode": "linux-gcc-x64",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json"
        }
    ],
    "version": 4
}